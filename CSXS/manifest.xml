<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" 
    ExtensionBundleId="com.alztod.essentials" 
    ExtensionBundleVersion="1.4.0" 
    ExtensionBundleName="AT-Essentials" 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.alztod.essentials" Version="1.4.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[17.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.alztod.essentials">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/script.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--enable-nodejs</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>AT-Essentials</Menu>
                    <Geometry>
                        <Size>
                            <Width>300</Width>
                            <Height>500</Height>
                        </Size>
                        <MinSize>
                            <Width>200</Width>
                            <Height>300</Height>
                        </MinSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./icons/icon.png</Icon>
                        <Icon Type="DarkNormal">./icons/icon.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>